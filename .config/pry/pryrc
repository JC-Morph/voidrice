def itersam( words )
  %i[elf robo stuffy old alien bass].each do |voice|
    file = "sam_#{words.split[0..3].join('_')}_#{voice}.wav"
    `sam #{samopts[voice]} -wav #{file} #{words}`
  end
end

def samopts
  {
    elf: '-pitch 64 -throat 110 -mouth 160',
    robo: '-pitch 60 -throat 190 -mouth 190',
    stuffy: '-pitch 72 -throat 110 -mouth 105',
    old: '-pitch 32 -throat 145 -mouth 145',
    alien: '-pitch 64 -throat 150 -mouth 200',
    bass: '-pitch 180 -throat 30 -mouth 15'
  }
end
